{
  "name": "@levibostian/decaf-script-git",
  "license": "MIT",
  "exports": {
    ".": "./script.ts"
  },
  "publish": {
    "include": [
      "LICENSE",
      "README.md",
      "script.ts",
      "deno.json",
      "deno.lock"
    ]
  },
  "imports": {
    "@levibostian/decaf-sdk": "jsr:@levibostian/decaf-sdk@0.7.0",
    "@levibostian/decaf-sdk/testing": "jsr:@levibostian/decaf-sdk@0.7.0/testing",
    "@levibostian/mock-a-bin": "jsr:@levibostian/mock-a-bin@1.1.0",
    "@david/dax": "jsr:@david/dax@0.43.2",
    "@std/assert": "jsr:@std/assert@1.0.14",
    "@std/cli/parse-args": "jsr:@std/cli@1.0.28/parse-args",
    "ventojs": "npm:ventojs@2.3.1"
  },
  "tasks": {
    "test": "deno test --allow-all --junit-path reports/junit.xml --coverage=reports/coverage/",
    "lint": "deno lint --fix",
    "compile": "deno compile --output $OUTPUT_FILE_NAME --allow-env --allow-net --allow-run --allow-read --allow-write --target $DENO_TARGET script.ts"
  }
}